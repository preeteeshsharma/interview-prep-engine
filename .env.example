ANTHROPIC_API_KEY=sk-ant-...

# Gemini via direct API key (optional, Vertex AI preferred if GOOGLE_CLOUD_PROJECT is set)
GEMINI_API_KEY=AIzaSy...

# Gemini via Google Cloud Vertex AI (preferred — higher rate limits, service account auth)
# Store the full JSON content of your service account key file as this env var
GOOGLE_CLOUD_PROJECT=my-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_WHATSAPP=whatsapp:+14155238886
TWILIO_TO_WHATSAPP=whatsapp:+91...
MAILGUN_SIGNING_KEY=...
GITHUB_TOKEN=ghp_...
GITHUB_VAULT_REPO=yourname/prep-vault   # create a private repo, name it anything
OWNER_EMAIL=you@example.com             # your identity in V1; replaced by User table in V2
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname  # from Supabase project settings → Database → Connection string (asyncpg URI)
ENV=development
